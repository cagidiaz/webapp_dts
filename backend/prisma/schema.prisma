  quarter        Int             @db.SmallInt
  month          Int             @db.SmallInt
  day            Int             @db.SmallInt
  day_of_week    Int             @db.SmallInt
  month_name     String          @db.VarChar(20)
  day_name       String          @db.VarChar(20)
  is_weekend     Boolean
  is_holiday     Boolean?        @default(false)
  fiscal_year    Int?            @db.SmallInt
  fiscal_quarter Int?            @db.SmallInt
  budgets        budgets[]
  sales_budgets  sales_budgets[]
  value_entries  value_entries[]

  @@schema("public")
}

model customers {
  id                       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id                String          @unique @db.VarChar(50)
  name                     String          @db.VarChar(255)
  balance_lcy              Decimal?        @default(0) @db.Decimal
  balance_due_lcy          Decimal?        @default(0) @db.Decimal
  credit_limit_lcy         Decimal?        @default(0) @db.Decimal
  blocked                  String?         @db.VarChar(20)
  privacy_blocked          Boolean?        @default(false)
  salesperson_code         String?         @db.VarChar(20)
  market_segment           String?         @db.VarChar(50)
  business_model           String?         @db.VarChar(50)
  total_sales              Decimal?        @default(0) @db.Decimal
  cost_profit_variance_lcy Decimal?        @default(0) @db.Decimal
  adjusted_profit          Decimal?        @default(0) @db.Decimal
  adjusted_profit_pct      Decimal?        @default(0) @db.Decimal
  order_margin             Decimal?        @default(0) @db.Decimal
  invoice_margin           Decimal?        @default(0) @db.Decimal
  address                  String?
  address_2                String?
  country_reg_code         String?         @db.VarChar(20)
  city                     String?         @db.VarChar(100)
  county                   String?         @db.VarChar(100)
  post_code                String?         @db.VarChar(20)
  phone_no                 String?         @db.VarChar(50)
  mobile_no                String?         @db.VarChar(50)
  email                    String?         @db.VarChar(255)
  home_page                String?         @db.VarChar(255)
  language_code            String?         @db.VarChar(10)
  vat_no                   String?         @db.VarChar(50)
  customer_posting_group   String?         @db.VarChar(50)
  payment_terms_code       String?         @db.VarChar(50)
  payment_method_code      String?         @db.VarChar(50)
  shipment_method_code     String?         @db.VarChar(50)
  shipping_agent_code      String?         @db.VarChar(50)
  payments_lcy             Decimal?        @default(0) @db.Decimal
  created_at               DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?       @default(now()) @db.Timestamptz(6)
  sales_rep                sales_reps?     @relation(fields: [salesperson_code], references: [code])
  sales_budgets            sales_budgets[]
  sales_orders             sales_orders[]

  @@schema("public")
}

model products {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  item_no             String             @unique @db.VarChar(50)
  description         String?            @db.VarChar(255)
  type                String?            @db.VarChar(50)
  inventory_qty       Float              @default(0) @db.Real
  is_assembly         Boolean?           @default(false)
  base_uom            String?            @db.VarChar(20)
  standard_cost       Decimal            @default(0) @db.Decimal(15, 2)
  unit_cost           Decimal            @default(0) @db.Decimal(15, 2)
  last_purchase_price Decimal            @default(0) @db.Decimal(15, 2)
  profit_margin_pct   Decimal            @default(0) @db.Decimal(15, 2)
  unit_price          Decimal            @default(0) @db.Decimal(15, 2)
  gen_bus_group       String?            @db.VarChar(50)
  vat_group           String?            @db.VarChar(20)
  vendor_no           String?            @db.VarChar(50)
  subfamily_code      String?            @db.VarChar(50)
  is_blocked          Boolean?           @default(false)
  last_date_modified  DateTime           @db.Date
  replenish_type      String?            @db.VarChar(50)
  created_at          DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?          @default(now()) @db.Timestamptz(6)
  category            product_categories? @relation(fields: [subfamily_code], references: [subfamily_code], onDelete: SetNull)
  sales_orders        sales_orders[]

  @@index([vendor_no], map: "idx_product_vendor")
  @@index([subfamily_code], map: "idx_product_subfamily")
  @@index([gen_bus_group], map: "idx_product_bus_group")
  @@schema("public")
}

model product_categories {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  family_code    String     @db.VarChar(50)
  subfamily_code String     @unique @db.VarChar(50)
  family_name    String?    @db.VarChar(255)
  subfamily_name String?    @db.VarChar(255)
  pm_code        String     @db.VarChar(50)
  created_at     DateTime?  @default(now()) @db.Timestamptz(6)
  products       products[]

  @@schema("public")
}

model sales_reps {
  code           String          @id @db.VarChar
  name           String
  commission_pct Decimal?        @default(0) @db.Decimal(5, 2)
  phone          String?         @db.VarChar
  created_at     DateTime?       @default(now()) @db.Timestamptz(6)
  customers      customers[]
  profiles       profiles[]
  sales_budgets  sales_budgets[]

  @@index([code], map: "idx_sales_reps_code")
  @@schema("public")
}

enum aal_level {
  aal1
  aal2
  aal3

  @@schema("auth")
}

enum code_challenge_method {
  s256
  plain

  @@schema("auth")
}

enum factor_status {
  unverified
  verified

  @@schema("auth")
}

enum factor_type {
  totp
  webauthn
  phone

  @@schema("auth")
}

enum one_time_token_type {
  confirmation_token
  reauthentication_token
  recovery_token
  email_change_token_new
  email_change_token_current
  phone_change_token

  @@schema("auth")
}

model sales_orders {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  posting_date             DateTime? @db.Date
  document_type            String?   @db.VarChar(50)
  type                     String?   @db.VarChar(50)
  document_number          String    @db.VarChar(50)
  item_code                String    @db.VarChar(50)
  description              String?   @db.Text
  unit_of_measure          String?   @db.VarChar(20)
  quantity                 Decimal?  @default(0) @db.Decimal(18, 4)
  outstanding_quantity     Decimal?  @default(0) @db.Decimal(18, 4)
  quantity_invoice         Decimal?  @default(0) @db.Decimal(18, 4)
  qty_shipped_not_invoiced Decimal?  @default(0) @db.Decimal(18, 4)
  unit_price               Decimal?  @default(0) @db.Decimal(18, 4)
  line_amount              Decimal?  @default(0) @db.Decimal(18, 4)
  customer_code            String    @db.VarChar(50)
  shipment_date            DateTime? @db.Date
  created_at               DateTime? @default(now()) @db.Timestamptz(6)
  updated_at               DateTime? @default(now()) @db.Timestamptz(6)

  customer                 customers @relation(fields: [customer_code], references: [client_id], onDelete: Cascade)
  product                  products  @relation(fields: [item_code], references: [item_no], onDelete: Cascade)

  @@index([customer_code], map: "idx_sales_orders_customer")
  @@index([item_code], map: "idx_sales_orders_item")
  @@index([document_number], map: "idx_sales_orders_doc_no")
  @@schema("public")
}
