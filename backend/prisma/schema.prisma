// Prisma ORM schema — will be configured to connect to Supabase PostgreSQL
// Schema will be generated in Phase 2 (Database & Authentication)
// See: Architecture.md Section 6 for the full SQL init schema

generator client {
  provider   = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}



// =============================================
// RBAC — Access Control
// =============================================

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(50)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  profiles    Profile[]
  roleModules RoleModule[]

  @@map("roles")
}

model Profile {
  id        String   @id @db.Uuid
  email     String   @unique @db.VarChar(255)
  firstName String?  @map("first_name") @db.VarChar(100)
  lastName  String?  @map("last_name") @db.VarChar(100)
  roleId    String?  @map("role_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  role      Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@index([roleId])
  @@map("profiles")
}

model Module {
  id        String  @id @default(uuid()) @db.Uuid
  name      String  @unique @db.VarChar(100)
  routePath String  @map("route_path") @db.VarChar(255)
  isActive  Boolean @default(true) @map("is_active")
  roleModules RoleModule[]

  @@map("modules")
}

model RoleModule {
  roleId   String  @map("role_id") @db.Uuid
  moduleId String  @map("module_id") @db.Uuid
  canView  Boolean @default(true) @map("can_view")

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([roleId, moduleId])
  @@map("role_modules")
}

// =============================================
// SIMULATION & FORECASTING
// =============================================

model ForecastScenario {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(100)
  description   String?
  isAiGenerated Boolean  @default(false) @map("is_ai_generated")
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  lines         ForecastLine[]

  @@map("forecast_scenarios")
}

model ForecastLine {
  id              String   @id @default(uuid()) @db.Uuid
  scenarioId      String   @map("scenario_id") @db.Uuid
  accountId       String   @map("account_id") @db.VarChar(50)
  periodDate      DateTime @map("period_date") @db.Date
  budgetAmount    Decimal  @default(0) @map("budget_amount") @db.Decimal(18, 2)
  confidenceLevel Decimal? @map("confidence_level") @db.Decimal(5, 2)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz

  scenario        ForecastScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId, periodDate])
  @@map("forecast_lines")
}

// =============================================
// SALES
// =============================================

model SalesBudget {
  id            Int      @id @default(autoincrement())
  salesRepCode  String   @map("sales_rep_code") @db.VarChar(50)
  customerCode  String   @map("customer_code") @db.VarChar(50)
  customerName  String?  @map("customer_name") @db.Text
  pmCode        String?  @map("pm_code") @db.VarChar(50)
  productId     String?  @map("product_id") @db.VarChar(50)
  subfamilyCode String?  @map("subfamily_code") @db.VarChar(50)
  productName   String?  @map("product_name") @db.Text
  targetUnits   Float?   @map("target_units") @db.Real
  unitPrice2025 Decimal? @map("unit_price_2025") @db.Decimal(18, 2)
  unitPrice2026 Decimal? @map("unit_price_2026") @db.Decimal(18, 2)
  targetRevenue Decimal? @map("target_revenue") @db.Decimal(18, 2)
  workingDays   Int?     @map("working_days") @db.SmallInt
  budgetDate    DateTime @map("budget_date") @db.Date
  monthlyBudget Decimal? @map("monthly_budget") @db.Decimal(18, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("sales_budgets")
}
